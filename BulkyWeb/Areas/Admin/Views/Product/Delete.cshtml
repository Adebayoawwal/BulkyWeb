@using BulkyWebModels.Models
@model Product
<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient mt-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Delete Product</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post">
            <input asp-for="Id" hidden />
            <div class="border p-3 mt-4">
                <div class="form-floating py-3 col-12">
                    <input asp-for="Title" disabled type="text" class="form-control border-0 shadow" />
                    <label asp-for="Title" class="ms-2">Product Name</label>
                </div>
                <div class="form-floating py-3 col-12">
                    <textarea asp-for="Description" type="text" class="form-control border-0 shadow"></textarea>
                    <label asp-for="Description" class="ms-2">Product Name</label>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>    
                <div class="mb-3 row p-1">
                    <label asp-for="ISBN" disabled class="ms-2"></label>
                    <input asp-for="ISBN" type="text" class="form-control border-0 shadow" />
                </div>
                <div class="mb-3 row p-1">
                    <label asp-for="Author" disabled class="ms-2"></label>
                    <input asp-for="Author" type="text" class="form-control border-0 shadow" />
                </div>
                <div class="mb-3 row p-1">
                    <label asp-for="ListPrice" disabled class="ms-2"></label>
                    <input asp-for="ListPrice" type="text" class="form-control border-0 shadow" />
                </div>
                <div class="mb-3 row p-1">
                    <label asp-for="Price" disabled class="ms-2"></label>
                    <input asp-for="Price" type="text" class="form-control border-0 shadow" />
                </div>
                <div class="mb-3 row p-1">
                    <label asp-for="Price50" disabled class="ms-2"></label>
                    <input asp-for="Price50" type="text" class="form-control border-0 shadow" />
                </div>
                <div class="mb-3 row p-1">
                    <label asp-for="Price100" disabled class="ms-2"></label>
                    <input asp-for="Price100" type="text" class="form-control border-0 shadow" />
                </div>
                <div class="row">
                    <div class="col-6 col-mb-3">
                        <button type="submit" class="btn btn-danger form-control">Delete</button>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary border form-control">Back to List</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>


